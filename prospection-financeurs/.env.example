# Ce projet réutilise automatiquement le .env racine du repo (ingest-habitat/.env)
# qui contient déjà DB_PASSWORD, SERPER_API_KEY, MISTRAL_API_KEY.
#
# Créer un .env ici UNIQUEMENT si vous voulez surcharger une valeur pour ce projet :
#
# SERPER_API_KEY=autre_clé
# MISTRAL_API_KEY=autre_clé
# DB_PASSWORD=autre_mot_de_passe
#
# Paramètres optionnels spécifiques à ce pipeline :
# VALIDATE_EMAILS=true
# MAX_CONTACTS_PER_ENTITY=5
# ENTITY_TYPES=departement,dirpjj,ars

# Modèle Mistral (optionnel)
MISTRAL_MODEL=mistral-small-latest

# Rate limiting (optionnel)
SERPER_DELAY_SECONDS=1.0
MISTRAL_DELAY_SECONDS=1.0
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0

# Types d'entités à traiter (optionnel, toutes par défaut)
# ENTITY_TYPES=departement,dirpjj,ars

# Validation croisée des emails (optionnel)
VALIDATE_EMAILS=true

# Nombre max de contacts par entité (0 = pas de limite)
MAX_CONTACTS_PER_ENTITY=5
